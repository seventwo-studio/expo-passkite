# PassKite Credentials Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# PASS IDENTITY
# =============================================================================

# Your Pass Type ID from Apple Developer Portal
# Format: pass.com.yourcompany.passname
PASSKITE_PASS_TYPE_ID=pass.com.example.mypass

# Your Apple Developer Team ID (10 characters)
# Find it at: https://developer.apple.com/account -> Membership Details
PASSKITE_TEAM_ID=ABCD123456

# =============================================================================
# SIGNING CREDENTIALS
# =============================================================================
# You can provide credentials in two ways:
# 1. Direct PEM content (replace newlines with \n)
# 2. File path prefixed with "file:" (e.g., file:./credentials/cert.pem)

# Apple Worldwide Developer Relations (WWDR) Certificate
# Download from: https://www.apple.com/certificateauthority/
# Use AppleWWDRCAG4.cer for passes created after Jan 2022
PASSKITE_WWDR_CERT=file:./credentials/wwdr.pem

# Your Pass Type ID Certificate (exported from Keychain as PEM)
PASSKITE_SIGNER_CERT=file:./credentials/signer-cert.pem

# Your Pass Type ID Private Key (exported from Keychain as PEM)
PASSKITE_SIGNER_KEY=file:./credentials/signer-key.pem

# Passphrase for the private key (if encrypted)
# Leave empty if your key is not password-protected
PASSKITE_SIGNER_KEY_PASSPHRASE=
