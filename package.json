{
  "name": "expo-passkite",
  "version": "0.1.0",
  "description": "Generate Apple Wallet passes (.pkpass) and add them to iOS Wallet or Google Wallet",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "bun run build:types && bun build ./src/index.ts --outdir ./build --target node --packages=external",
    "build:types": "tsc --emitDeclarationOnly --declaration --declarationMap --outDir ./build",
    "clean": "rm -rf build",
    "prepare": "bun run clean && bun run build",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "keywords": [
    "expo",
    "react-native",
    "passkit",
    "apple-wallet",
    "google-wallet",
    "pkpass"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^18.0.0",
    "expo": "~52.0.0",
    "expo-module-scripts": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "node-forge": "^1.3.1"
  }
}
