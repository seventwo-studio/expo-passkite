{
  "name": "expo-passkite",
  "version": "2.0.0",
  "description": "Generate Apple Wallet passes, add them to iOS Wallet, and save Google Wallet JWTs on Android",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./server": {
      "types": "./build/server.d.ts",
      "default": "./build/server.js"
    },
    "./app.plugin.js": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bun run build:types && bun build ./src/index.ts ./src/server.ts ./src/withPasskite.ts --outdir ./build --target node --format cjs --packages external",
    "build:types": "tsc --emitDeclarationOnly --declaration --declarationMap --outDir ./build",
    "clean": "rm -rf build",
    "prepare": "bun run clean && bun run build",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "docs": "bun run --cwd docs dev",
    "docs:build": "bun run --cwd docs build",
    "docs:preview": "bun run --cwd docs preview"
  },
  "keywords": [
    "expo",
    "react-native",
    "passkit",
    "apple-wallet",
    "google-wallet",
    "pkpass"
  ],
  "author": "Luca Silverentand <luca@onezero.company>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seventwo-studio/expo-passkite.git"
  },
  "homepage": "https://github.com/seventwo-studio/expo-passkite#readme",
  "bugs": {
    "url": "https://github.com/seventwo-studio/expo-passkite/issues"
  },
  "peerDependencies": {
    "expo": "55.0.24",
    "react": "19.2.6",
    "react-native": "0.83.9"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@types/bun": "1.3.13",
    "@types/node": "25.6.0",
    "@types/node-forge": "1.3.14",
    "@types/react": "19.2.14",
    "expo": "55.0.23",
    "expo-module-scripts": "55.0.2",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "jszip": "3.10.1",
    "node-forge": "1.4.0"
  }
}
