{
  "name": "expo-passkite",
  "version": "1.0.2",
  "description": "Generate Apple Wallet passes (.pkpass) and add them to iOS Wallet or Google Wallet",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "scripts": {
    "build": "bun run build:types && bun build ./src/index.ts --outdir ./build --target node --packages=external",
    "build:types": "tsc --emitDeclarationOnly --declaration --declarationMap --outDir ./build",
    "clean": "rm -rf build",
    "prepare": "bun run clean && bun run build",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "docs": "bun run --cwd docs dev",
    "docs:build": "bun run --cwd docs build",
    "docs:preview": "bun run --cwd docs preview"
  },
  "keywords": [
    "expo",
    "react-native",
    "passkit",
    "apple-wallet",
    "google-wallet",
    "pkpass"
  ],
  "author": "Luca Silverentand <luca@onezero.company>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seventwo-studio/expo-passkite.git"
  },
  "homepage": "https://github.com/seventwo-studio/expo-passkite#readme",
  "bugs": {
    "url": "https://github.com/seventwo-studio/expo-passkite/issues"
  },
  "peerDependencies": {
    "expo": "52.0.48",
    "react": "19.2.3",
    "react-native": "0.83.1"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@types/bun": "1.3.6",
    "@types/node": "20.19.28",
    "@types/node-forge": "1.3.14",
    "@types/react": "18.3.27",
    "expo": "52.0.48",
    "expo-module-scripts": "4.1.10",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "jszip": "3.10.1",
    "node-forge": "1.3.3"
  }
}
